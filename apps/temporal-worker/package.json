{
  "name": "@self-healing-ci/temporal-worker",
  "version": "0.0.0-development",
  "description": "Temporal worker for orchestrating self-healing CI workflows",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/auth-app": "^6.0.0",
    "@octokit/rest": "^20.0.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/exporter-jaeger": "^1.20.0",
    "@opentelemetry/resources": "^1.20.0",
    "@opentelemetry/sdk-trace-base": "^1.20.0",
    "@opentelemetry/sdk-trace-node": "^1.20.0",
    "@opentelemetry/semantic-conventions": "^1.20.0",
    "@self-healing-ci/claude": "workspace:*",
    "@self-healing-ci/freestyle": "workspace:*",
    "@self-healing-ci/lean": "workspace:*",
    "@temporalio/activity": "^1.8.0",
    "@temporalio/client": "^1.8.0",
    "@temporalio/common": "^1.8.0",
    "@temporalio/worker": "^1.8.0",
    "@temporalio/workflow": "^1.8.0",
    "aws-sdk": "^2.1531.0",
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "diff": "^5.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.0",
    "ioredis": "^5.3.2",
    "jszip": "^3.10.1",
    "node-cron": "^3.0.3",
    "ora": "^8.0.0",
    "parse-diff": "^0.11.1",
    "prom-client": "^15.0.0",
    "redis": "^4.6.12",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "nock": "^13.4.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "^20.0.0"
  },
  "keywords": [
    "temporal",
    "workflow",
    "orchestration",
    "self-healing-ci",
    "ci-cd"
